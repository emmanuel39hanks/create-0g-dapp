{
  "name": "create-0g-app",
  "version": "0.1.0",
  "description": "Scaffold a Next.js app with the 0G decentralized AI network — Storage, Chain, Compute, KV, DA",
  "type": "module",
  "bin": {
    "create-0g-app": "./dist/index.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "0g",
    "blockchain",
    "ai",
    "scaffold",
    "nextjs",
    "create-app",
    "decentralized",
    "storage",
    "compute",
    "agents"
  ],
  "author": "Schema Labs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
